# ─────────────────────────────────────────────────────────────────
# SwarmFrame Engine — Environment Variables
# Copy this file to .env and fill in your keys.
# All REACT_APP_ variables are bundled into the frontend by CRA.
# ─────────────────────────────────────────────────────────────────

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# Supermemory API Key  (memory layer — stores/retrieves node outputs across sessions)
# Get yours at: https://supermemory.ai
REACT_APP_SUPERMEMORY_API_KEY=your_supermemory_api_key_here
